CREATE TABLE IF NOT EXISTS BillOfLading (
    PartitionKey   TEXT NOT NULL UNIQUE PRIMARY KEY,
    TransactionId TEXT NOT NULL DEFAULT '',
    FirstName         TEXT NOT NULL DEFAULT '',
    LastName      TEXT NOT NULL DEFAULT '',
