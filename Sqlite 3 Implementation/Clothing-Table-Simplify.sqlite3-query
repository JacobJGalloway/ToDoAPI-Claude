-- database: ./WarehouseData.db3
-- Removes detail columns now owned by SKUCatalog
-- Uses recreate pattern for SQLite 3 compatibility

CREATE TABLE IF NOT EXISTS Clothing_New (
    PartitionKey   TEXT NOT NULL UNIQUE PRIMARY KEY,
    RowKey         TEXT NOT NULL DEFAULT '',
    SKUMarker      TEXT NOT NULL DEFAULT '',
    UnloadedDate   TEXT NOT NULL DEFAULT ''
);

INSERT INTO Clothing_New (PartitionKey, RowKey, SKUMarker, UnloadedDate)
    SELECT PartitionKey, RowKey, SKUMarker, UnloadedDate FROM Clothing;

DROP TABLE Clothing;

ALTER TABLE Clothing_New RENAME TO Clothing;
